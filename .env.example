# Environment Variables

# Backend Configuration
REACT_APP_API_URL=http://localhost:5000/api

# API Endpoints
REACT_APP_TICKETS_URL=http://localhost:5000/api/tickets
REACT_APP_ASSETS_URL=http://localhost:5000/api/assets
REACT_APP_USERS_URL=http://localhost:5000/api/users
REACT_APP_DASHBOARD_URL=http://localhost:5000/api/dashboard
REACT_APP_APPROVALS_URL=http://localhost:5000/api/approvals

# ManageEngine Integration
REACT_APP_MANAGEENGINE_BASE_URL=https://your-manageengine-instance.com
REACT_APP_MANAGEENGINE_API_KEY=your-manageengine-api-key
REACT_APP_MANAGEENGINE_TECHNICIAN_KEY=your-manageengine-technician-key
REACT_APP_MANAGEENGINE_WEBHOOK_SECRET=your-webhook-secret-key
