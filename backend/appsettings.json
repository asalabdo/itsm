{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=itsm_db;Username=postgres;Password=postgres"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://localhost:5000",
      "http://localhost:88"
    ]
  },
  "ManageEngine": {
    "BaseUrl": "https://your-manageengine-instance.com",
    "ApiKey": "your-manageengine-api-key",
    "TechnicianKey": "your-manageengine-technician-key",
    "SyncEnabled": false,
    "SyncDirection": "bidirectional",
    "SyncIntervalMinutes": 15,
    "WebhookSecret": "your-webhook-secret-key",
    "FieldMappings": {
      "IncidentId": "id",
      "Title": "title",
      "Description": "description",
      "Status": "status",
      "Priority": "priority",
      "Assignee": "technician",
      "CreatedDate": "created_time",
      "UpdatedDate": "updated_time",
      "SlaDueDate": "due_by_time"
    }
  },
  "Jwt": {
    "Key": "dev-only-secret-key-change-me-in-production-min-32-chars!!",
    "Issuer": "ITSMSystem",
    "Audience": "ITSMUsers",
    "ExpiryMinutes": 480
  }
}
