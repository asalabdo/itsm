{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ManageEngine": {
    "BaseUrl": "https://your-manageengine-dev-instance.com",
    "ApiKey": "dev-api-key",
    "TechnicianKey": "dev-technician-key",
    "SyncEnabled": false,
    "SyncDirection": "import",
    "SyncIntervalMinutes": 60,
    "WebhookSecret": "dev-webhook-secret",
    "FieldMappings": {
      "IncidentId": "id",
      "Title": "title",
      "Description": "description",
      "Status": "status",
      "Priority": "priority",
      "Assignee": "technician",
      "CreatedDate": "created_time",
      "UpdatedDate": "updated_time",
      "SlaDueDate": "due_by_time"
    }
  }
}
